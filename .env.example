FLASK_SECRET=change-me
RCAI_USER=admin
PASS_HASH_FILE=/opt/robot/etc/robot-console-ai.passhash

ROBOT_CONSOLE_AI_SERVICE=robot-console-ai
ROBOT_CONSOLE_AI_TITLE=Robot Console AI
ROBOT_CONSOLE_AI_PORT=8080
ROBOT_CONSOLE_AI_REPO_DIR=/opt/robot/robot-console-ai
ROBOT_CONSOLE_AI_UPDATE_SCRIPT=/opt/robot/bin/robot-console-ai-update
ROBOT_CONSOLE_AI_RESTART_SCRIPT=/opt/robot/bin/robot-console-ai-restart

HAILO_OLLAMA_SERVICE=hailo-ollama
HAILO_OLLAMA_HEALTH_URL=http://127.0.0.1:8000/hailo/v1/list
HAILO_OLLAMA_CONTROL_SCRIPT=
HAILO_OLLAMA_API_BASE_URL=http://127.0.0.1:8000
ROBOT_TEXT_COMMAND_MODEL=qwen2:1.5b
ROBOT_REGISTRY_FILE=/opt/robot/robot-console/robots.json
ROBOT_BRAIN_API_TOKEN=change-me-robot-brain-token

VLM_SERVICE_NAME=vlm-service
VLM_HEALTH_URL=http://127.0.0.1:8090/healthz
VLM_CONTROL_SCRIPT=
VLM_SERVICE_PORT=8090
VLM_API_BASE_URL=http://127.0.0.1:8090
VLM_MODEL_ID=local-vlm
VLM_BACKEND_CMD=
HAILO_VLM_BACKEND_MODE=direct
VLM_BACKEND_PERSISTENT=1
VLM_BACKEND_TIMEOUT=120
VLM_DEFAULT_PROMPT=Describe this image in a concise way and answer the user's question if one is provided.
HAILO_VLM_APP_DIR=
HAILO_VLM_COMMAND_TEMPLATE=

OPEN_WEBUI_SERVICE=open-webui
OPEN_WEBUI_HEALTH_URL=http://127.0.0.1:3000
OPEN_WEBUI_CONTROL_SCRIPT=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_ROBOT_ID=
TELEGRAM_EXECUTION_MODE=live
ROBOT_BRAIN_API_BASE_URL=http://127.0.0.1:8080/api/brain
